{
  "name": "react-hono-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write . --ignore-path .gitignore",
    "clean": "git clean -xdf .cache .turbo dist node_modules .tanstack",
    "db:push": "pnpm --filter=@repo/db push",
    "db:studio": "pnpm --filter=@repo/db studio"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@types/bun": "^1.2.21",
    "@types/node": "^22.15.29",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3"
  }
}
