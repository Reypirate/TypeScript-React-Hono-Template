# Client runtime variables exposed through /api/runtime.js
VITE_APP_URL=http://localhost:4000
VITE_API_URL=http://localhost:4001

# Server
NODE_ENV=development
PORT=4001
STATIC_ROOT=apps/web/dist
DATABASE_URL=postgres://postgres:password@localhost:5432/app
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:4001/api/auth

# Optional mail support for Better Auth password reset and verification emails
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM=no-reply@localhost

# Optional S3-compatible object storage, compatible with the MinIO compose service
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=ap-southeast-1
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=app
FORCE_PATH_STYLE=true
