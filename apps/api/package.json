{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- bun run --hot index.ts",
    "build": "bun build --minify --sourcemap --target=bun --outdir=dist index.ts",
    "start": "bun --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "nodemailer": "^8.0.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "dotenv-cli": "catalog:",
    "tsx": "^4.21.0"
  }
}
